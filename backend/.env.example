# ============================================================
# JWM KAJIADO CHURCH - BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!
# ============================================================

PORT=5000

# --- Admin Credentials (hardcoded login) ---
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# --- Church Email (Gmail) ---
# Use a Gmail account. Enable "App Passwords" in your Google account
# Go to: myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=jesuswinnerministrykajiado@gmail.com
EMAIL_PASS=
CHURCH_EMAIL=info@jwmkajiado.org

# --- Google Sheets ---
# After following the Google Sheets setup guide below, paste your values here
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- M-Pesa (Safaricom Daraja API) ---
# Register at: https://developer.safaricom.co.ke
# Start with sandbox, then switch to production when ready
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-render-url.onrender.com/api/mpesa/callback
# Set to "sandbox" for testing, "live" for production
MPESA_ENV=sandbox

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000
